# ============================================
# 公众号比价机器人配置文件
# 复制此文件为 .env 并填写实际配置
# ============================================

# 应用配置
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 微信配置（必填）
# 登录微信公众平台 -> 开发 -> 基本配置 获取
WECHAT_TOKEN=your_wechat_token_here
WECHAT_APPID=your_appid_here
WECHAT_APPSECRET=your_appsecret_here

# Redis配置（必填）
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=your_password

# 淘宝客配置（选填，不填则不启用淘宝功能）
# 申请地址：https://pub.alimama.com/
TAOBAO_APP_KEY=your_app_key
TAOBAO_APP_SECRET=your_app_secret
TAOBAO_ADZONE_ID=your_adzone_id
TAOBAO_SITE_ID=your_site_id

# 京东联盟配置（选填）
# 申请地址：https://union.jd.com/
JD_APP_KEY=your_app_key
JD_APP_SECRET=your_app_secret
JD_UNION_ID=your_union_id
JD_POSITION_ID=your_position_id

# 拼多多配置（选填）
# 申请地址：https://open.pinduoduo.com/
PDD_CLIENT_ID=your_client_id
PDD_CLIENT_SECRET=your_client_secret
PDD_PID=your_pid

# 限流配置
RATE_LIMIT_PER_MINUTE=10

# 缓存配置（秒）
CACHE_TTL_PRODUCT=3600
CACHE_TTL_SEARCH=1800
CACHE_TTL_LINK=7200
